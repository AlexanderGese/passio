{
  "$schema": "passio-seed@1",
  "name": "spotify-remote-command",
  "version": "0.1.0",
  "description": "Spotify playback + playlist remote — play, skip, queue, transfer, build playlists from prompts. $29.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-spotify-remote-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["api.spotify.com"], "secrets": ["access_token"] },
  "contributes": {
    "tools": ["me","play","pause","next","prev","queue","devices","transfer","search","playlist_create","playlist_add","now_playing","save_track"],
    "tabs": [{ "id": "spotify-remote-command-panel", "title": "Spotify", "icon": "🎵", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "access_token", "label": "Spotify OAuth access token", "type": "secret" }
    ]
  }
}
