{
  "$schema": "passio-seed@1",
  "name": "github-command",
  "version": "0.1.0",
  "description": "Full GitHub remote — issues, PRs, reviews, releases, repos, stars. Triage a whole org from Passio chat. $49.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-github-command",
  "entry": "./index.js",
  "language": "js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": {
    "network": ["api.github.com", "uploads.github.com"],
    "secrets": ["gh_token"]
  },
  "contributes": {
    "tools": [
      "me","search_issues","issue_create","issue_comment","issue_close","issue_reopen",
      "pr_review","pr_merge","pr_request_reviewers","release_create","repo_create","repo_visibility",
      "star","unstar","notifications","mark_notifications_read","file_read","file_write",
      "gist_create","autopilot_tick","autopilot_enable","autopilot_dry_run","recent_actions"
    ],
    "tabs": [{ "id": "github-command-panel", "title": "GitHub", "icon": "⎋", "panel": "./panel.js" }],
    "scheduler": [{ "id": "autopilot", "every_seconds": 3600 }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "gh_token", "label": "GitHub fine-grained PAT", "description": "Needs repo + workflow scopes on target repos.", "type": "secret" },
      { "id": "autopilot_enabled", "label": "Autopilot on (nightly triage)", "type": "boolean", "default": false },
      { "id": "autopilot_dry_run", "label": "Autopilot dry-run", "type": "boolean", "default": true },
      { "id": "autopilot_repos", "label": "Target repos (owner/repo, comma)", "type": "string", "default": "" }
    ]
  }
}
