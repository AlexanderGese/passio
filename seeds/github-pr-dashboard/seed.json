{
  "$schema": "passio-seed@1",
  "name": "github-pr-dashboard",
  "version": "0.1.0",
  "description": "Your PRs + review-requested, across all repos. Needs a GitHub token.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "api.github.com"
    ],
    "secrets": [
      "gh_token"
    ]
  },
  "contributes": {
    "tabs": [
      {
        "id": "gh-pr-panel",
        "title": "PRs",
        "icon": "⎋",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 600
      }
    ],
    "tools": [
      "check"
    ]
  }
}
