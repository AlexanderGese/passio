{
  "$schema": "passio-seed@1",
  "name": "slack-admin-command",
  "version": "0.1.0",
  "description": "Full Slack user remote — post as you, create channels, threads, reminders, status, react, DM. $39.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-slack-admin-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["slack.com"], "secrets": ["token"] },
  "contributes": {
    "tools": ["post","post_thread","dm","react","list_channels","create_channel","invite","reminder_add","reminder_list","set_status","history","search","delete"],
    "tabs": [{ "id": "slack-admin-command-panel", "title": "Slack", "icon": "💬", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "token", "label": "Slack user token (xoxp-…)", "type": "secret" }
    ]
  }
}
