{
  "$schema": "passio-seed@1",
  "name": "smart-bcc",
  "version": "0.1.0",
  "description": "Auto-BCC yourself on outgoing mail when to-address matches a rule (regex list).",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "tools": [
      "match"
    ],
    "settings": [
      {
        "id": "patterns",
        "label": "Regex patterns (comma)",
        "type": "string",
        "default": "^client-.*@, ^boss@"
      }
    ]
  }
}
