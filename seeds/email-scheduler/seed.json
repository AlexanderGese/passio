{
  "$schema": "passio-seed@1",
  "name": "email-scheduler",
  "version": "0.1.0",
  "description": "Queue an email to be sent at a specific time (via Passio's SMTP).",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "tabs": [
      {
        "id": "email-scheduler-panel",
        "title": "Send later",
        "icon": "⏰",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 60
      }
    ],
    "tools": [
      "queue",
      "list"
    ]
  }
}
