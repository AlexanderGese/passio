{
  "$schema": "passio-seed@1",
  "name": "x-command",
  "version": "0.1.0",
  "description": "Full X (Twitter) remote — tweet, reply, like, retweet, delete, timeline, search — plus an opt-in AI autopilot that can draft and ship posts on a schedule. You supply X API v2 credentials. $39.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-x-command",
  "entry": "./index.js",
  "language": "js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": {
    "network": ["api.twitter.com", "api.x.com"],
    "secrets": ["bearer_token", "oauth1_consumer_key", "oauth1_consumer_secret", "oauth1_access_token", "oauth1_access_secret"]
  },
  "contributes": {
    "tools": [
      "tweet",
      "reply",
      "like",
      "unlike",
      "retweet",
      "unretweet",
      "delete",
      "timeline",
      "mentions",
      "search",
      "me",
      "autopilot_tick",
      "autopilot_enable",
      "autopilot_dry_run",
      "recent_posts"
    ],
    "tabs": [{ "id": "x-command-panel", "title": "X", "icon": "🐦", "panel": "./panel.js" }],
    "scheduler": [{ "id": "autopilot", "every_seconds": 3600 }],
    "settings": [
      { "id": "license", "label": "License key", "description": "From Gumroad after purchase.", "type": "secret" },
      { "id": "bearer_token", "label": "X API bearer token (v2 app-only)", "description": "Read-only operations (search, timelines). From developer.x.com.", "type": "secret" },
      { "id": "oauth1_consumer_key", "label": "Consumer key (OAuth 1.0a)", "description": "Required for posting. From your X app.", "type": "secret" },
      { "id": "oauth1_consumer_secret", "label": "Consumer secret", "type": "secret" },
      { "id": "oauth1_access_token", "label": "Access token (your user's)", "type": "secret" },
      { "id": "oauth1_access_secret", "label": "Access secret", "type": "secret" },
      { "id": "autopilot_enabled", "label": "Autopilot on", "description": "When on, Passio auto-decides hourly whether to tweet.", "type": "boolean", "default": false },
      { "id": "autopilot_dry_run", "label": "Autopilot dry-run", "description": "Drafts without posting. On by default.", "type": "boolean", "default": true },
      { "id": "autopilot_max_per_day", "label": "Max tweets per day", "type": "number", "default": 2, "min": 0, "max": 50, "step": 1 },
      { "id": "autopilot_min_gap_min", "label": "Min gap between tweets (min)", "type": "number", "default": 240, "min": 10, "max": 1440, "step": 10 },
      { "id": "autopilot_topics", "label": "Topics / themes (comma)", "type": "string", "default": "" },
      { "id": "style_guide", "label": "Voice / style guide", "description": "How you write on X. Autopilot follows this.", "type": "string", "default": "short, specific, no hype, no emojis, no threads unless essential" }
    ]
  }
}
