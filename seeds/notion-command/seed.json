{
  "$schema": "passio-seed@1",
  "name": "notion-command",
  "version": "0.1.0",
  "description": "Notion workspace automation — create pages, query databases, update blocks, write from templates. $39.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-notion-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["api.notion.com"], "secrets": ["token"] },
  "contributes": {
    "tools": ["db_query","page_create","page_update","block_append","block_list","search","user_me"],
    "tabs": [{ "id": "notion-command-panel", "title": "Notion", "icon": "📝", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "token", "label": "Integration token (secret_…)", "type": "secret" }
    ]
  }
}
