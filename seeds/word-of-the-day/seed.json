{
  "$schema": "passio-seed@1",
  "name": "word-of-the-day",
  "version": "0.1.0",
  "description": "One interesting English word/day with definition, pulled from Merriam-Webster RSS.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "www.merriam-webster.com"
    ]
  },
  "contributes": {
    "widgets": [
      {
        "id": "word-of-day-chip",
        "slot": "header",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "am",
        "every_seconds": 3600
      }
    ],
    "tools": [
      "today"
    ]
  }
}
