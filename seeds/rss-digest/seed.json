{
  "$schema": "passio-seed@1",
  "name": "rss-digest",
  "version": "0.1.0",
  "description": "Morning read across your Passio-configured RSS feeds — titled summary.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "tabs": [
      {
        "id": "rss-digest-panel",
        "title": "Digest",
        "icon": "📰",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "morning",
        "every_seconds": 86400
      }
    ],
    "tools": [
      "run"
    ]
  }
}
