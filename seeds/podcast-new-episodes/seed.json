{
  "$schema": "passio-seed@1",
  "name": "podcast-new-episodes",
  "version": "0.1.0",
  "description": "RSS-based podcast tracker: paste feed URLs, get new episodes since last check.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "*"
    ]
  },
  "contributes": {
    "tabs": [
      {
        "id": "podcast-panel",
        "title": "Podcasts",
        "icon": "🎙",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 3600
      }
    ],
    "tools": [
      "check"
    ],
    "settings": [
      {
        "id": "feeds",
        "label": "Feed URLs (newline)",
        "type": "string",
        "default": ""
      }
    ]
  }
}
