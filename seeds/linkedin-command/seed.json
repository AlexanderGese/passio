{
  "$schema": "passio-seed@1",
  "name": "linkedin-command",
  "version": "0.1.0",
  "description": "LinkedIn remote — share posts, comment, send messages, manage invites. Includes opt-in AI autopilot with hard daily caps. $49.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-linkedin-command",
  "entry": "./index.js",
  "language": "js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": {
    "network": ["api.linkedin.com"],
    "secrets": ["access_token", "urn"]
  },
  "contributes": {
    "tools": [
      "share_text",
      "share_article",
      "comment",
      "like",
      "feed",
      "message",
      "me",
      "connections_count",
      "autopilot_tick",
      "autopilot_enable",
      "autopilot_dry_run",
      "recent_posts"
    ],
    "tabs": [{ "id": "linkedin-command-panel", "title": "LinkedIn", "icon": "in", "panel": "./panel.js" }],
    "scheduler": [{ "id": "autopilot", "every_seconds": 3600 }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "access_token", "label": "LinkedIn OAuth 2.0 access token", "description": "3-legged OAuth with w_member_social + r_liteprofile + r_emailaddress.", "type": "secret" },
      { "id": "urn", "label": "Your person URN", "description": "From /v2/me response id, formatted urn:li:person:<id>.", "type": "string" },
      { "id": "autopilot_enabled", "label": "Autopilot on", "type": "boolean", "default": false },
      { "id": "autopilot_dry_run", "label": "Autopilot dry-run", "type": "boolean", "default": true },
      { "id": "autopilot_max_per_day", "label": "Max posts per day", "type": "number", "default": 1 },
      { "id": "autopilot_min_gap_min", "label": "Min gap (min)", "type": "number", "default": 720 },
      { "id": "autopilot_topics", "label": "Topics (comma)", "type": "string", "default": "" },
      { "id": "style_guide", "label": "Voice / style guide", "type": "string", "default": "professional, specific, 2-3 sentences, no corporate-speak" }
    ]
  }
}
