{
  "$schema": "passio-seed@1",
  "name": "spotify-now-playing",
  "version": "0.1.0",
  "description": "What's playing + save-to-liked chip. Needs an OAuth token.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "api.spotify.com"
    ],
    "secrets": [
      "spotify_token"
    ]
  },
  "contributes": {
    "widgets": [
      {
        "id": "spotify-chip",
        "slot": "header",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 30
      }
    ],
    "tools": [
      "now",
      "like"
    ]
  }
}
