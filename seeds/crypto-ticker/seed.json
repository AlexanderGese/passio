{
  "$schema": "passio-seed@1",
  "name": "crypto-ticker",
  "version": "0.1.0",
  "description": "BTC/ETH (or any symbol) spot price in the header, refreshed every minute.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "api.coingecko.com"
    ]
  },
  "contributes": {
    "widgets": [
      {
        "id": "crypto-ticker-chip",
        "slot": "header",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 60
      }
    ],
    "tools": [
      "price"
    ],
    "settings": [
      {
        "id": "coin",
        "label": "Coin id",
        "type": "string",
        "default": "bitcoin"
      }
    ]
  }
}
