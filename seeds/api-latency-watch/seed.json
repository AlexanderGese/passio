{
  "$schema": "passio-seed@1",
  "name": "api-latency-watch",
  "version": "0.1.0",
  "description": "Pings URLs on a schedule, records latency, shows a mini chart in a tab.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "*"
    ]
  },
  "contributes": {
    "tabs": [
      {
        "id": "api-latency-panel",
        "title": "Latency",
        "icon": "📈",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 60
      }
    ],
    "tools": [
      "ping"
    ],
    "settings": [
      {
        "id": "urls",
        "label": "URLs (newline)",
        "type": "string",
        "default": "https://api.github.com"
      }
    ]
  }
}
