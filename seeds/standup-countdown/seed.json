{
  "$schema": "passio-seed@1",
  "name": "standup-countdown",
  "version": "0.1.0",
  "description": "Countdown chip to the next standup (daily 09:30 by default). Clickable to copy prep.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "widgets": [
      {
        "id": "standup-countdown-chip",
        "slot": "header",
        "panel": "./panel.js"
      }
    ],
    "settings": [
      {
        "id": "time",
        "label": "Standup time (HH:MM)",
        "type": "string",
        "default": "09:30"
      }
    ]
  }
}
