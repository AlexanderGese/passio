{
  "$schema": "passio-seed@1",
  "name": "shopify-command",
  "version": "0.1.0",
  "description": "Shopify Admin remote — orders, inventory, customers, fulfillments, draft-order creation, customer replies. $79.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-shopify-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["*.myshopify.com"], "secrets": ["admin_token"] },
  "contributes": {
    "tools": ["orders","order","order_note","order_fulfill","order_refund","customer","customer_search","product_list","product_update","inventory_set","draft_order_create"],
    "tabs": [{ "id": "shopify-command-panel", "title": "Shopify", "icon": "🛍", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "shop", "label": "Shop subdomain (without .myshopify.com)", "type": "string" },
      { "id": "admin_token", "label": "Admin API access token (shpat_…)", "type": "secret" }
    ]
  }
}
