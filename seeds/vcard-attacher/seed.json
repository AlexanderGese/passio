{
  "$schema": "passio-seed@1",
  "name": "vcard-attacher",
  "version": "0.1.0",
  "description": "Appends a signature block to outgoing drafts. Keeps the block you author.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "tools": [
      "append"
    ],
    "settings": [
      {
        "id": "signature",
        "label": "Signature",
        "type": "string",
        "default": "—\\nsent from Passio"
      }
    ]
  }
}
