{
  "$schema": "passio-seed@1",
  "name": "youtube-subs",
  "version": "0.1.0",
  "description": "New uploads from channels you sub to, via their /feeds/videos.xml RSS.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "www.youtube.com",
      "youtube.com"
    ]
  },
  "contributes": {
    "tabs": [
      {
        "id": "yt-subs-panel",
        "title": "YT",
        "icon": "▶",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 3600
      }
    ],
    "tools": [
      "check"
    ],
    "settings": [
      {
        "id": "channels",
        "label": "Channel IDs (comma)",
        "type": "string",
        "default": ""
      }
    ]
  }
}
