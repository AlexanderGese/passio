{
  "$schema": "passio-seed@1",
  "name": "telegram-bridge",
  "version": "0.1.0",
  "description": "Send messages to your Telegram Saved-Messages via a personal bot token.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "api.telegram.org"
    ],
    "secrets": [
      "bot_token",
      "chat_id"
    ]
  },
  "contributes": {
    "tools": [
      "send"
    ],
    "settings": [
      {
        "id": "bot_token",
        "label": "Bot token",
        "type": "secret"
      },
      {
        "id": "chat_id",
        "label": "Your chat id",
        "type": "string"
      }
    ]
  }
}
