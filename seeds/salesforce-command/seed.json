{
  "$schema": "passio-seed@1",
  "name": "salesforce-command",
  "version": "0.1.0",
  "description": "Salesforce remote — accounts, opportunities, contacts, tasks, SOQL queries. $79.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-salesforce-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["*.salesforce.com", "*.my.salesforce.com", "login.salesforce.com"], "secrets": ["access_token"] },
  "contributes": {
    "tools": ["soql","account","account_update","opp_list","opp_create","contact_upsert","task_create","describe"],
    "tabs": [{ "id": "salesforce-command-panel", "title": "SFDC", "icon": "☁", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "access_token", "label": "OAuth access token", "type": "secret" },
      { "id": "instance_url", "label": "Instance URL (https://your.my.salesforce.com)", "type": "string" }
    ]
  }
}
