{
  "$schema": "passio-seed@1",
  "name": "clock-sync",
  "version": "0.1.0",
  "description": "Header chip showing atomic-clock drift — red when your system clock is off by more than 1s.",
  "author": "Passio team",
  "entry": "./index.js",
  "permissions": { "network": ["worldtimeapi.org"] },
  "contributes": {
    "tools": ["check"],
    "widgets": [{ "id": "clock-sync-chip", "slot": "header", "panel": "./panel.js" }],
    "scheduler": [{ "id": "tick", "every_seconds": 900 }]
  }
}
