{
  "$schema": "passio-seed@1",
  "name": "notion-mirror",
  "version": "0.1.0",
  "description": "Two-way mirror between a Notion DB and a vault folder. Stub — needs your Notion token.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "api.notion.com"
    ],
    "secrets": [
      "notion_token"
    ]
  },
  "contributes": {
    "tools": [
      "sync"
    ],
    "settings": [
      {
        "id": "db_id",
        "label": "Notion DB id",
        "type": "string"
      }
    ]
  }
}
