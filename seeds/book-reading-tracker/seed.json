{
  "$schema": "passio-seed@1",
  "name": "book-reading-tracker",
  "version": "0.1.0",
  "description": "Books you're reading + % progress. Weekly reminder to log.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "tabs": [
      {
        "id": "books-panel",
        "title": "Books",
        "icon": "📖",
        "panel": "./panel.js"
      }
    ],
    "tools": [
      "add",
      "update",
      "list"
    ],
    "scheduler": [
      {
        "id": "weekly",
        "every_seconds": 604800
      }
    ]
  }
}
