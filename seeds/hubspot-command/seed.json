{
  "$schema": "passio-seed@1",
  "name": "hubspot-command",
  "version": "0.1.0",
  "description": "HubSpot CRM remote — contacts, deals, notes, engagements, email drafts. $49.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-hubspot-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["api.hubapi.com"], "secrets": ["access_token"] },
  "contributes": {
    "tools": ["contact_search","contact_create","contact_update","deal_list","deal_create","note_create","engagement_list","email_draft","task_create"],
    "tabs": [{ "id": "hubspot-command-panel", "title": "HubSpot", "icon": "🧡", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "access_token", "label": "Private app access token", "type": "secret" }
    ]
  }
}
