{
  "$schema": "passio-seed@1",
  "name": "arxiv-fresh",
  "version": "0.1.0",
  "description": "Today's preprints in your field via arxiv.org/rss.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "export.arxiv.org"
    ]
  },
  "contributes": {
    "tabs": [
      {
        "id": "arxiv-fresh-panel",
        "title": "arXiv",
        "icon": "📑",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 21600
      }
    ],
    "tools": [
      "latest"
    ],
    "settings": [
      {
        "id": "cat",
        "label": "arXiv category",
        "type": "string",
        "default": "cs.AI"
      }
    ]
  }
}
