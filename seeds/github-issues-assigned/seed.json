{
  "$schema": "passio-seed@1",
  "name": "github-issues-assigned",
  "version": "0.1.0",
  "description": "Issues assigned to you across all repos. Shares gh_token with github-pr-dashboard.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "api.github.com"
    ],
    "secrets": [
      "gh_token"
    ]
  },
  "contributes": {
    "tabs": [
      {
        "id": "gh-issues-panel",
        "title": "Issues",
        "icon": "🐛",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 600
      }
    ],
    "tools": [
      "check"
    ]
  }
}
