{
  "$schema": "passio-seed@1",
  "name": "discord-command",
  "version": "0.1.0",
  "description": "Full Discord bot-token remote — post, create channels/threads, schedule events, manage roles, moderate. Autopilot for community cadence. $29.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-discord-command",
  "entry": "./index.js",
  "language": "js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["discord.com"], "secrets": ["bot_token"] },
  "contributes": {
    "tools": [
      "send","edit","delete","guild_info","channels","threads","create_channel","create_thread",
      "add_role","remove_role","ban","kick","scheduled_event_create","events","members",
      "autopilot_tick","autopilot_enable","autopilot_dry_run"
    ],
    "tabs": [{ "id": "discord-command-panel", "title": "Discord", "icon": "💬", "panel": "./panel.js" }],
    "scheduler": [{ "id": "autopilot", "every_seconds": 3600 }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "bot_token", "label": "Bot token (Bot …)", "type": "secret" },
      { "id": "default_guild", "label": "Default guild ID", "type": "string" },
      { "id": "autopilot_enabled", "type": "boolean", "label": "Autopilot on", "default": false },
      { "id": "autopilot_dry_run", "type": "boolean", "label": "Dry-run", "default": true },
      { "id": "autopilot_channel", "type": "string", "label": "Autopilot channel id" },
      { "id": "autopilot_daily_msg", "type": "string", "label": "Daily message template", "default": "gm team — what are we shipping today?" }
    ]
  }
}
