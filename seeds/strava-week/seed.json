{
  "$schema": "passio-seed@1",
  "name": "strava-week",
  "version": "0.1.0",
  "description": "km run/ridden this week. Needs a Strava API access token.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "www.strava.com"
    ],
    "secrets": [
      "strava_token"
    ]
  },
  "contributes": {
    "widgets": [
      {
        "id": "strava-chip",
        "slot": "header",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 3600
      }
    ],
    "tools": [
      "week"
    ]
  }
}
