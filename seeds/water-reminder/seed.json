{
  "$schema": "passio-seed@1",
  "name": "water-reminder",
  "version": "0.1.0",
  "description": "Drinks-water nudge every 90 min with a streak counter.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "widgets": [
      {
        "id": "water-reminder-chip",
        "slot": "header",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "nudge",
        "every_seconds": 5400
      }
    ],
    "tools": [
      "log"
    ]
  }
}
