{
  "$schema": "passio-seed@1",
  "name": "vercel-command",
  "version": "0.1.0",
  "description": "Vercel remote — deploys, env vars, rollbacks, domain ops, preview URLs. $39.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-vercel-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["api.vercel.com"], "secrets": ["token"] },
  "contributes": {
    "tools": ["me","projects","deployments","deployment","promote","rollback","env_list","env_set","env_unset","domains","logs"],
    "tabs": [{ "id": "vercel-command-panel", "title": "Vercel", "icon": "▲", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "token", "label": "Vercel API token", "type": "secret" },
      { "id": "team_id", "label": "Team id (optional)", "type": "string" }
    ]
  }
}
