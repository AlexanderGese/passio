{
  "$schema": "passio-seed@1",
  "name": "ghost-command",
  "version": "0.1.0",
  "description": "Ghost CMS remote — create/update/publish posts, schedule, newsletter triggers. $29.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-ghost-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["*"], "secrets": ["admin_key"] },
  "contributes": {
    "tools": ["posts","post","post_create","post_update","post_delete","publish","schedule","tags"],
    "tabs": [{ "id": "ghost-command-panel", "title": "Ghost", "icon": "👻", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "url", "label": "Ghost site URL", "type": "string", "default": "https://example.ghost.io" },
      { "id": "admin_key", "label": "Admin API key (id:secret)", "type": "secret" }
    ]
  }
}
