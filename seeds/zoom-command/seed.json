{
  "$schema": "passio-seed@1",
  "name": "zoom-command",
  "version": "0.1.0",
  "description": "Zoom remote — schedule, list, delete meetings; pull recordings + transcripts. $39.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-zoom-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["api.zoom.us"], "secrets": ["oauth_token"] },
  "contributes": {
    "tools": ["me","meeting_create","meetings","meeting_delete","recordings","transcript_fetch","users"],
    "tabs": [{ "id": "zoom-command-panel", "title": "Zoom", "icon": "📹", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "oauth_token", "label": "OAuth access token (S2S or user)", "type": "secret" }
    ]
  }
}
