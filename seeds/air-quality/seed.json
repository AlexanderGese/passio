{
  "$schema": "passio-seed@1",
  "name": "air-quality",
  "version": "0.1.0",
  "description": "Air Quality Index for your location via WAQI (free token required).",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {
    "network": [
      "api.waqi.info"
    ],
    "secrets": [
      "waqi_token"
    ]
  },
  "contributes": {
    "widgets": [
      {
        "id": "air-quality-chip",
        "slot": "header",
        "panel": "./panel.js"
      }
    ],
    "scheduler": [
      {
        "id": "tick",
        "every_seconds": 1800
      }
    ],
    "tools": [
      "aqi"
    ],
    "settings": [
      {
        "id": "city",
        "label": "City / station",
        "type": "string",
        "default": "here"
      }
    ]
  }
}
