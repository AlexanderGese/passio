{
  "$schema": "passio-seed@1",
  "name": "elevenlabs-command",
  "version": "0.1.0",
  "description": "ElevenLabs remote — list voices, synthesize text to speech, clone voices, fetch history. $39.",
  "author": "Passio team",
  "homepage": "https://alexandergese.gumroad.com/l/passio-elevenlabs-command",
  "entry": "./index.js",
  "licensed": true,
  "licensePublicKey": "REPLACE_WITH_BASE64_ED25519_PUBKEY",
  "permissions": { "network": ["api.elevenlabs.io"], "secrets": ["api_key"] },
  "contributes": {
    "tools": ["voices","speak","history","clone","user"],
    "tabs": [{ "id": "elevenlabs-command-panel", "title": "11L", "icon": "🔊", "panel": "./panel.js" }],
    "settings": [
      { "id": "license", "label": "License key", "type": "secret" },
      { "id": "api_key", "label": "ElevenLabs API key", "type": "secret" },
      { "id": "default_voice", "label": "Default voice id", "type": "string" }
    ]
  }
}
