{
  "$schema": "passio-seed@1",
  "name": "daily-intent",
  "version": "0.1.0",
  "description": "Morning \"what matters today\" prompt — logs to vault + surfaces in briefing.",
  "author": "Passio team",
  "entry": "./index.js",
  "language": "js",
  "permissions": {},
  "contributes": {
    "tools": [
      "set",
      "today"
    ],
    "scheduler": [
      {
        "id": "am",
        "every_seconds": 3600
      }
    ]
  }
}
